# ══════════════════════════════════════════════════════════════════════════════
# Folio — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
# ══════════════════════════════════════════════════════════════════════════════

# ── Anthropic (AI generation — briefings, quiz, podcast scripts) ──────────────
# Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Tavily (web search for briefing generation) ───────────────────────────────
# Free tier: 1,000 searches/month. Get from https://app.tavily.com/
TAVILY_API_KEY=tvly-...

# ── Clerk (authentication) ────────────────────────────────────────────────────
# Get from https://dashboard.clerk.com/ → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...

# Clerk redirect URLs (copy exactly)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# Clerk proxy (required in production — bypasses Cloudflare conflict)
# Tells the Clerk JS SDK to route requests through our proxy instead of directly.
NEXT_PUBLIC_CLERK_PROXY_URL=https://www.folioapp.co.uk/__clerk
# The actual Clerk Frontend API URL the proxy forwards to (decoded from publishable key).
# Only needed if it differs from what the publishable key decodes to.
# CLERK_PROXY_TARGET=https://xxx.clerk.accounts.dev

# ── Stripe (subscriptions & payments) ─────────────────────────────────────────
# Get from https://dashboard.stripe.com/
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
# Price ID for the £4/month subscription product
STRIPE_PRICE_ID=price_...
# Webhook signing secret — from Stripe Dashboard → Webhooks → your endpoint
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Upstash Redis (production storage & rate limiting) ────────────────────────
# Create a free database at https://upstash.com/
# Or use Vercel → Storage → Upstash KV and copy the env vars from there.
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# ── ElevenLabs (text-to-speech for podcast) ───────────────────────────────────
# Creator plan required (100k chars/month). Get from https://elevenlabs.io/
ELEVENLABS_API_KEY=sk_...

# ── Resend (transactional email — welcome emails) ─────────────────────────────
# Free tier: 100 emails/day. Get from https://resend.com/
RESEND_API_KEY=re_...

# ── App URL ───────────────────────────────────────────────────────────────────
# Used for Stripe redirect URLs. In production, use your real domain.
NEXT_PUBLIC_APP_URL=https://your-domain.co.uk

# ── Cron job secret ───────────────────────────────────────────────────────────
# Protects GET /api/generate from unauthenticated triggers.
# Generate a random secret: openssl rand -hex 32
# Must match exactly in Vercel → Settings → Environment Variables.
CRON_SECRET=your-random-hex-secret-here

# ── Admin user ID ─────────────────────────────────────────────────────────────
# Clerk user ID of the site admin. Only this user can manually trigger briefing generation.
# Find your user ID in Clerk Dashboard → Users → click your account.
ADMIN_USER_ID=user_...

# ── DEV ONLY: Preview mode ────────────────────────────────────────────────────
# WARNING: Setting this to 'true' bypasses ALL subscription/paywall checks.
# NEVER set this in production. Local dev only.
# PREVIEW_MODE=true

# ── DEV ONLY: Skip web search ─────────────────────────────────────────────────
# Set to 'false' to use Tavily web search. Set to 'true' to use training data only.
# USE_WEB_SEARCH=true
